<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gallery - NOORA PASTRY</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f8f8f8;
}

header{
background:#2E7D32;
padding:20px;
text-align:center;
color:white;
}

.gallery{
padding:50px 8%;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:20px;
}

.gallery img{
width:100%;
height:280px;
object-fit:cover;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,.15);
transition:.3s;
}

.gallery img:hover{
transform:scale(1.03);
}

footer{
background:#222;
color:white;
text-align:center;
padding:20px;
}
</style>
</head>
<body>

<header>
<h1>NOORA PASTRY GALLERY</h1>
</header>

<section class="gallery">

<img src="https://images.unsplash.com/photo-1509440159596-0249088772ff?w=800" alt="Bread">

<img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=800" alt="Cake">

<img src="https://images.unsplash.com/photo-1509365465985-25d11c17e812?w=800" alt="Pastry">

<img src="https://images.unsplash.com/photo-1519864600265-abb23847ef2c?w=800" alt="Cake">

<img src="https://images.unsplash.com/photo-1483695028939-5bb13f8648b0?w=800" alt="Bread">

<img src="https://images.unsplash.com/photo-1555507036-ab1f4038808a?w=800" alt="Pastry">

</section>

<footer>
© 2026 NOORA PASTRY | All Rights Reserved
</footer>

</body>
</html>
